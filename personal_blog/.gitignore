# =============================================================================
# 个人博客项目 - Git 忽略文件配置
# =============================================================================

# =============================================================================
# Python / Django
# =============================================================================
# Python 缓存文件
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 虚拟环境
venv/
env/
ENV/
.venv/

# Django 相关
*.log
local_settings.py
db.sqlite3
db.sqlite3-journal

# 静态文件收集目录
staticfiles/

# =============================================================================
# Node.js / Vue
# =============================================================================
# 依赖目录
node_modules/

# 构建输出
dist/
dist-ssr/
*.local

# 日志
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# 编辑器
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# =============================================================================
# Docker
# =============================================================================
# 数据卷（保留目录但忽略内容）
data/db/*
!data/db/.gitkeep
data/media/*
!data/media/.gitkeep

# =============================================================================
# 系统文件
# =============================================================================
.DS_Store
Thumbs.db
*.pem

# =============================================================================
# 环境变量文件
# =============================================================================
.env
.env.local
.env.*.local

# =============================================================================
# 测试和覆盖率
# =============================================================================
.coverage
htmlcov/
.tox/
.pytest_cache/

# =============================================================================
# 其他
# =============================================================================
*.bak
*.tmp
*.temp
